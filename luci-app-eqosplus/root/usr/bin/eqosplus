#!/bin/sh

# Copyright (C) 2006 OpenWrt.org
# Copyright 2022-2025 lava <byl0561@gmail.com>

crrun=$1
crid=$2
NAME=eqosplus
IDLIST="/var/$NAME.idlist"
NETWORKS="/var/$NAME.networks"
GENERATION="/var/$NAME.generation"
LOGFILE="/tmp/$NAME.log"
LOG_LEVEL=$(uci -q get "$NAME.@eqosplus[0].log_level" 2>/dev/null || echo 0)
bin_tc=/usr/sbin/tc
bin_ip=/usr/sbin/ip

LOCKFILE="/tmp/$NAME.op.lock"

# Acquire operation lock only for mutating commands (not status/log)
case "$crrun" in
	"status"|"log")
		;;
	*)
		exec 9>"$LOCKFILE"
		# BusyBox flock lacks -w (timeout); poll with -n instead.
		_i=0; while [ "$_i" -lt 10 ]; do flock -n 9 && break; sleep 1; _i=$((_i + 1)); done
		[ "$_i" -ge 10 ] && { echo "eqosplus: could not acquire lock, aborting" >&2; exit 1; }
		trap 'exec 9>&-; rm -f /var/$NAME.tmpid.* 2>/dev/null' EXIT HUP TERM INT
		[ -f "$IDLIST" ]   || touch "$IDLIST"
		[ -f "$NETWORKS" ] || touch "$NETWORKS"
		;;
esac

safe_mktemp() {
	local f
	f=$(mktemp "/var/$NAME.tmpid.XXXXXX") || {
		log_msg 1 "mktemp failed (disk full?), aborting operation"
		return 1
	}
	echo "$f"
}

bump_generation() {
	local gen
	gen=$(cat "$GENERATION" 2>/dev/null || echo 0)
	echo $((gen + 1)) > "$GENERATION" || log_msg 1 "failed to update GENERATION (disk full?)"
}

# Load shared IDLIST & file operations (uses safe_mktemp/log_msg via defaults)
. /usr/lib/eqosplus/idlist_helpers.sh

# Logging: 0=off, 1=error, 2=info, 3=debug
_log_check=0
log_msg() {
	local level=$1; shift
	[ "$LOG_LEVEL" -ge "$level" ] 2>/dev/null || return
	local tag=""
	case $level in
		1) tag="ERROR" ;;
		2) tag="INFO" ;;
		3) tag="DEBUG" ;;
	esac
	local _up; read _up _ < /proc/uptime 2>/dev/null
	echo "${_up:-?} [$tag] $*" >> "$LOGFILE"
	# Throttle size check: every 20 writes
	_log_check=$((_log_check + 1))
	if [ "$_log_check" -ge 20 ]; then
		_log_check=0
		local size
		size=$(stat -c %s "$LOGFILE" 2>/dev/null || wc -c < "$LOGFILE" 2>/dev/null) || size=0
		if [ "$size" -gt 102400 ]; then
			tail -c 51200 "$LOGFILE" > "${LOGFILE}.tmp" && mv "${LOGFILE}.tmp" "$LOGFILE" || rm -f "${LOGFILE}.tmp"
		fi
	fi
}

dbg_tc() {
	log_msg 3 "tc $*"
	$bin_tc "$@"
	local ret=$?
	[ $ret -eq 0 ] || log_msg 1 "tc FAILED (exit=$ret): $*"
	return $ret
}
dbg_ip() {
	log_msg 3 "ip $*"
	$bin_ip "$@"
	local ret=$?
	[ $ret -eq 0 ] || log_msg 1 "ip FAILED (exit=$ret): $*"
	return $ret
}
# Load shared libraries
EQOS_TC="dbg_tc"
EQOS_IP="dbg_ip"
. /usr/lib/eqosplus/core.sh
. /usr/lib/eqosplus/sched.sh
. /usr/lib/eqosplus/uci_helpers.sh

# Cache uci show output to avoid repeated subprocess spawns during startup
_uci_cache=""
uci_show_cached() {
	[ -n "$_uci_cache" ] || _uci_cache=$(uci show "$NAME" 2>/dev/null)
	echo "$_uci_cache"
}

# Get sorted list of enabled network names (single awk pass, no grep/sed chain)
_enabled_networks_cache=""
get_enabled_networks() {
	[ -n "$_enabled_networks_cache" ] || \
		_enabled_networks_cache=$(uci_show_cached | awk -F. "
			/network_[^.]+\.[^=]*enable='1'/{
				s=\$0; sub(/.*network_/,\"\",s); sub(/\\..*/,\"\",s); sub(/\\[.*]/,\"\",s)
				if(s!=\"\") a[s]=1
			} END{for(k in a) print k}" | sort -u)
	echo "$_enabled_networks_cache"
}

# Extract a field from uci_show_cached for a given section (no uci fork)
# Uses grep -F for literal matching (safe with brackets in section names)
_get_uci_field() {
	local section=$1 field=$2
	echo "$_uci_cache" | grep -F ".${section}.${field}='" | head -1 | _uci_unquote
}

# Batch-extract mac, download, upload for a rule section in one awk pass (1 fork instead of 12)
# Output: mac|dl_kbit|ul_kbit (pipe-delimited, rates pre-converted from MB/s to kbit/s)
_get_uci_rule_fields() {
	echo "$_uci_cache" | awk -v sect=".${1}." '
	function uq(s) {
		sub(/[^=]*=/, "", s)
		gsub(/\047\\\047\047/, "\001", s)
		gsub(/\047/, "", s)
		gsub(/\001/, "\047", s)
		return s
	}
	!gm && index($0, sect "mac=\047")      { m = uq($0); gm = 1 }
	!gd && index($0, sect "download=\047") { d = uq($0); gd = 1 }
	!gu && index($0, sect "upload=\047")   { u = uq($0); gu = 1 }
	END { d += 0; u += 0; printf "%s|%d|%d\n", m, d * 8000, u * 8000 }
	'
}

# Cache network.X.device lookups to avoid repeated uci forks
# Uses eval-based variables (safe: UCI net names are [a-zA-Z0-9_])
# Falls back to ifstatus for dynamic interfaces (WireGuard, GRE, etc.)
# that have no UCI device field — the kernel creates them at runtime.
get_net_device() {
	local net=$1 cached
	# Validate network name before eval (defense-in-depth against injection)
	case "$net" in ''|*[!a-zA-Z0-9_]*) return 1 ;; esac
	eval "cached=\${_ndc_${net}}"
	if [ -n "$cached" ]; then
		[ "$cached" = "__empty__" ] && return 1
		echo "$cached"
		return 0
	fi
	local dev
	dev=$(uci -q get "network.${net}.device" 2>/dev/null)
	# Fallback: query runtime interface status for dynamic interfaces
	[ -n "$dev" ] || dev=$(ifstatus "$net" 2>/dev/null | jsonfilter -e '@.l3_device' 2>/dev/null)
	[ -n "$dev" ] || { eval "_ndc_${net}=__empty__"; return 1; }
	eval "_ndc_${net}=\$dev"
	echo "$dev"
}

# Cache firewall config once to avoid repeated uci show firewall forks.
# No invalidation needed: firewall config is not modified by eqosplus,
# and each eqosplus invocation is a separate process (cache starts empty).
_fw_cache=""
fw_show_cached() {
	[ -n "$_fw_cache" ] || _fw_cache=$(uci show firewall 2>/dev/null)
	echo "$_fw_cache"
}

# Build zone<->network mapping cache (single awk pass over firewall config)
_zone_map_cache=""
_build_zone_map() {
	[ -n "$_zone_map_cache" ] && return
	_zone_map_cache=$(fw_show_cached | awk '
	/\.name=/ {
		sect = $0; sub(/\.name=.*/, "", sect)
		val = $0; sub(/[^=]*=/, "", val)
		gsub(/\047\\\047\047/, "\001", val); gsub(/\047/, "", val); gsub(/\001/, "\047", val)
		zone_name[sect] = val
	}
	/\.network=/ {
		sect = $0; sub(/\.network=.*/, "", sect)
		val = $0; sub(/[^=]*=/, "", val)
		gsub(/\047\\\047\047/, "\001", val); gsub(/\047/, "", val); gsub(/\001/, "\047", val)
		zone_nets[sect] = val
	}
	END {
		for (s in zone_name) {
			n = split(zone_nets[s], arr, /[ \t]+/)
			for (i = 1; i <= n; i++) {
				if (arr[i] != "") print arr[i] "=" zone_name[s]
			}
		}
	}')
}

# Find the firewall zone name for a given network (pure shell, no fork)
get_zone_for_network() {
	_build_zone_map
	local _line
	while IFS= read -r _line; do
		[ "${_line%%=*}" = "$1" ] && { echo "${_line#*=}"; return 0; }
	done <<EOF
$_zone_map_cache
EOF
	return 1
}

# Get all networks belonging to a given firewall zone (pure shell, no fork)
get_networks_in_zone() {
	_build_zone_map
	local _line
	while IFS= read -r _line; do
		[ "${_line#*=}" = "$1" ] && echo "${_line%%=*}"
	done <<EOF
$_zone_map_cache
EOF
}

start_network() {
	local network dev
	network=$1
	dev=$(get_net_device "$network")
	if [ -z "$dev" ]; then
		log_msg 1 "start_network: network $network has no device, skipping"
		return 1
	fi
	log_msg 2 "start_network $network dev=$dev"

	# Teardown any existing tc infrastructure, then reinitialize cleanly.
	# tc qdisc del root cascades to all child classes/filters/qdiscs,
	# which is more thorough and faster than iterating individual classes.
	if $bin_tc qdisc show dev "$dev" 2>/dev/null | grep -q "htb"; then
		log_msg 2 "start_network: dev=$dev already initialized, teardown and reinit"
		eqos_teardown_dev "$dev"
	fi
	if ! eqos_init_dev "$dev"; then
		log_msg 1 "start_network: eqos_init_dev failed for dev=$dev, skipping"
		return 1
	fi

	# Add bypass for same-zone networks (ensures same-zone traffic skips rate limiting)
	local zone_bypass=$(_get_uci_field "@eqosplus[0]" "zone_bypass")
	local my_zone
	[ "$zone_bypass" != "0" ] && my_zone=$(get_zone_for_network "$network")
	if [ -n "$my_zone" ]; then
		local bypass_prio=100
		# Collect all peer device names (single pass)
		local peer_devs=""
		for peer_net in $(get_networks_in_zone "$my_zone"); do
			local peer_dev=$(get_net_device "$peer_net")
			[ -n "$peer_dev" ] && peer_devs="${peer_devs:+$peer_devs }$peer_dev"
		done
		if [ -n "$peer_devs" ]; then
			# Single ip + awk call to collect all subnets (replaces 4N forks with 1)
			local _bp_subnets _bp_had_fail=false
			_bp_subnets=$(ip -o addr show 2>/dev/null | awk -v devs="$peer_devs" '
			BEGIN { n = split(devs, d, " "); for (i = 1; i <= n; i++) want[d[i]] = 1 }
			{
				if (!($2 in want)) next
				if ($3 == "inet") print "ip " $4
				else if ($3 == "inet6" && $0 !~ /scope link/) print "ipv6 " $4
			}')
			while read proto subnet; do
				[ -n "$proto" ] || continue
				if [ "$bypass_prio" -gt 1099 ]; then
					log_msg 1 "bypass: prio $bypass_prio exceeds limit 1099, skipping $subnet"
					break
				fi
				log_msg 2 "bypass: zone=$my_zone $proto $subnet"
				if ! eqos_add_bypass "$dev" "$subnet" "$proto" "$bypass_prio"; then
					log_msg 1 "bypass: FAILED to add $proto bypass for $subnet on $dev"
					_bp_had_fail=true
				fi
				bypass_prio=$((bypass_prio + 1))
			done <<EOF
$_bp_subnets
EOF
			if $_bp_had_fail; then
				log_msg 1 "bypass: some bypass rules failed for zone=$my_zone on dev=$dev"
			fi
		fi
	fi

	local tmpf
	tmpf=$(safe_mktemp) || return 1
	{ cat "$NETWORKS" 2>/dev/null; echo "${network}"; } | sort -u > "$tmpf" \
		&& mv "$tmpf" "$NETWORKS" \
		|| { log_msg 1 "start_network: failed to update $NETWORKS"; rm -f "$tmpf"; return 1; }

	# If another running network shares this device, its tc rules were destroyed
	# by the teardown+reinit above. Re-add its rules to restore QoS.
	# (Mirrors the shared-device handling in stop_network.)
	local other
	while IFS= read -r other; do
		[ -n "$other" ] || continue
		[ "$other" = "$network" ] && continue
		[ "$(get_net_device "$other")" = "$dev" ] || continue
		log_msg 2 "start_network: dev=$dev shared by $other, re-adding its rules"
		_readd_network_rules "$other"
	done < "$NETWORKS" 2>/dev/null
}

stop_network() {
	local network dev
	network=$1
	dev=$(get_net_device "$network")
	if [ -z "$dev" ]; then
		log_msg 1 "stop_network: network $network has no device, skipping"
		_file_remove_exact_line "$NETWORKS" "$network"
		return
	fi
	log_msg 2 "stop_network $network dev=$dev"

	# Remove this network from NETWORKS first
	_file_remove_exact_line "$NETWORKS" "$network"

	# Remove this network's rules from IDLIST
	_idlist_remove_network "$network"

	# Check if another network shares this device
	local other_shared=""
	while IFS= read -r other; do
		[ -n "$other" ] || continue
		[ "$(get_net_device "$other")" = "$dev" ] && { other_shared="$other"; break; }
	done < "$NETWORKS" 2>/dev/null

	if [ -n "$other_shared" ]; then
		# Device shared: rebuild tc infrastructure via start_network for the other network.
		# This tears down and reinits the device, clearing stale rules from the stopped network.
		log_msg 2 "stop_network: dev=$dev shared by $other_shared, rebuilding tc infrastructure"
		start_network "$other_shared" \
			&& _readd_network_rules "$other_shared" \
			|| log_msg 1 "stop_network: rebuild failed for $other_shared on dev=$dev"
	else
		eqos_teardown_dev "$dev"
	fi
}

sync_networks() {
	local all_networks running_networks need_start need_stop

	all_networks=$(get_enabled_networks)
	running_networks=$(sort "$NETWORKS" 2>/dev/null)

	local tmp_all tmp_run
	tmp_all=$(safe_mktemp) || return 1
	tmp_run=$(safe_mktemp) || { rm -f "$tmp_all"; return 1; }
	echo "$all_networks" > "$tmp_all"
	echo "$running_networks" > "$tmp_run"
	need_start=$(grep -Fxvf "$tmp_run" "$tmp_all")
	need_stop=$(grep -Fxvf "$tmp_all" "$tmp_run")
	rm -f "$tmp_all" "$tmp_run"

	while IFS= read -r item; do
		[ -n "$item" ] && start_network "$item"
	done <<EOF
$need_start
EOF

	while IFS= read -r item; do
		[ -n "$item" ] && stop_network "$item"
	done <<EOF
$need_stop
EOF
}

stop_qos() {
	while IFS= read -r item; do
		[ -n "$item" ] && stop_network "$item"
	done < "$NETWORKS" 2>/dev/null
}

cleanup_orphaned_rules() {
	local changed=false
	# Cache network config once (1 fork) instead of per-network uci get (N forks).
	# Dynamic interfaces (WireGuard, GRE) may not have a device field or may not be
	# up yet at boot time — only delete rules for truly removed networks.
	local _net_cfg
	_net_cfg=$(uci show network 2>/dev/null)
	for section in $(uci_show_cached | awk '/\]=network_/ { match($0, /@network_[^.\[]+/); if (RSTART) { s=substr($0, RSTART, RLENGTH); if (!seen[s]++) print s } }'); do
		local network="${section#@network_}"; network="${network%%\[*}"
		# Pure shell match: "network.<name>=" only matches section definition lines,
		# not field lines (which have "network.<name>.<field>=").
		# Safe because network names are [a-zA-Z0-9_] — no regex metachar risk.
		case "$_net_cfg" in
			*"network.${network}="*)
				;;  # network exists in UCI
			*)
				log_msg 2 "cleanup: removing orphaned rules for network $network (no UCI section)"
				while uci -q delete "$NAME.@network_${network}[0]" 2>/dev/null; do :; done
				changed=true
				;;
		esac
	done
	$changed && { uci commit "$NAME"; _uci_cache=""; _enabled_networks_cache=""; }
}

init_qosplus() {
	sync_networks
}

cal_uuid() {
	local network rule_id network_id found n
	network="${1%%\[*}"
	rule_id="${1#*\[}"; rule_id="${rule_id%\]}"
	case "$rule_id" in ''|*[!0-9]*) log_msg 1 "cal_uuid: invalid rule_id '$rule_id'"; return 1 ;; esac

	# 从 UCI 配置读取所有已启用网络，排序后确定位置（确定性索引）
	local all_nets
	all_nets=$(get_enabled_networks)

	network_id=0
	found=false
	for n in $all_nets; do
		[ "$network" = "$n" ] && { found=true; break; }
		network_id=$((network_id + 1))
	done

	if [ "$found" = "false" ]; then
		log_msg 1 "cal_uuid: network '$network' not found in UCI config"
		return 1
	fi

	# Classid layout: bypass prios use 100-1099, rule classids start at (0+11)*100=1100.
	# Each network gets 100 slots; *2 spacing leaves room for future per-direction IDs.
	# Max 50 rules per network (rule_id 0-49).
	if [ "$rule_id" -ge 50 ] 2>/dev/null; then
		log_msg 1 "cal_uuid: rule_id=$rule_id exceeds max 49 for network '$network'"
		return 1
	fi
	local uuid=$(( (network_id + 11) * 100 + rule_id * 2 ))
	if [ "$uuid" -ge 65535 ]; then
		log_msg 1 "cal_uuid: classid $uuid overflows 16-bit limit for network '$network'"
		return 1
	fi
	echo "$uuid"
}

del_id() {
	local addr network dev id
	[ -n "$_uci_cache" ] || _uci_cache=$(uci show "$NAME" 2>/dev/null)
	addr=$(_get_uci_field "@network_$1" "mac")
	network="${1%%\[*}"
	dev=$(get_net_device "$network") || {
		log_msg 1 "del_id: network $network has no device, skipping"
		return 1
	}
	id=$(cal_uuid "$1") || { log_msg 1 "del_id: skipping $1, network not found"; return 1; }

	# Clean up ghost tc rules: if the old device differs from the current one,
	# delete stale rules on the old device before cleaning up the current one.
	local old_dev
	old_dev=$(_idlist_get_device "$1")
	if [ -n "$old_dev" ] && [ "$old_dev" != "$dev" ]; then
		log_msg 2 "del_id $1: device changed $old_dev -> $dev, cleaning ghost rules"
		eqos_del_id "$old_dev" "$id"
	fi

	log_msg 2 "del_id $1 id=$id addr=$addr dev=$dev"
	eqos_del_id "$dev" "$id"

	# Accumulate for batch flush if active, otherwise write immediately
	if [ -n "$_batch_mode" ]; then
		_pending_dels="${_pending_dels:+$_pending_dels
}$1"
	else
		_idlist_remove_entry "$1"
	fi
}

add_mac() {
	local mac DL UL network dev id _fields
	[ -n "$_uci_cache" ] || _uci_cache=$(uci show "$NAME" 2>/dev/null)
	_fields=$(_get_uci_rule_fields "@network_$1")
	mac="${_fields%%|*}"; _fields="${_fields#*|}"
	DL="${_fields%%|*}"
	UL="${_fields#*|}"
	DL=${DL:-0}; UL=${UL:-0}
	network="${1%%\[*}"
	dev=$(get_net_device "$network") || {
		log_msg 1 "add_mac: network $network has no device, skipping"
		return 1
	}
	id=$(cal_uuid "$1") || { log_msg 1 "add_mac: skipping $1, network not found"; return 1; }

	# Clean up ghost tc rules if the device changed since last add
	local old_dev
	old_dev=$(_idlist_get_device "$1")
	if [ -n "$old_dev" ] && [ "$old_dev" != "$dev" ]; then
		log_msg 2 "add_mac $1: device changed $old_dev -> $dev, cleaning ghost rules"
		eqos_del_id "$old_dev" "$id"
	fi

	log_msg 2 "add_mac $1 id=$id mac=$mac UL=${UL}kbit DL=${DL}kbit dev=$dev"
	if ! eqos_add_mac "$dev" "$id" "$mac" "$DL" "$UL"; then
		log_msg 1 "add_mac: eqos_add_mac failed for $1"
		return 1
	fi

	# Accumulate for batch flush if active, otherwise write immediately
	if [ -n "$_batch_mode" ]; then
		_pending_adds="${_pending_adds:+$_pending_adds
}$1:$dev"
	else
		_idlist_add_entry "$1" "$dev"
	fi
}

add_ip() {
	local ip_addr DL UL network dev id _fields
	[ -n "$_uci_cache" ] || _uci_cache=$(uci show "$NAME" 2>/dev/null)
	_fields=$(_get_uci_rule_fields "@network_$1")
	ip_addr="${_fields%%|*}"; _fields="${_fields#*|}"
	DL="${_fields%%|*}"
	UL="${_fields#*|}"
	DL=${DL:-0}; UL=${UL:-0}
	network="${1%%\[*}"
	dev=$(get_net_device "$network") || {
		log_msg 1 "add_ip: network $network has no device, skipping"
		return 1
	}
	id=$(cal_uuid "$1") || { log_msg 1 "add_ip: skipping $1, network not found"; return 1; }

	# Clean up ghost tc rules if the device changed since last add
	local old_dev
	old_dev=$(_idlist_get_device "$1")
	if [ -n "$old_dev" ] && [ "$old_dev" != "$dev" ]; then
		log_msg 2 "add_ip $1: device changed $old_dev -> $dev, cleaning ghost rules"
		eqos_del_id "$old_dev" "$id"
	fi

	log_msg 2 "add_ip $1 id=$id ip=$ip_addr UL=${UL}kbit DL=${DL}kbit dev=$dev"
	if ! eqos_add_ip "$dev" "$id" "$ip_addr" "$DL" "$UL"; then
		log_msg 1 "add_ip: eqos_add_ip failed for $1"
		return 1
	fi

	# Accumulate for batch flush if active, otherwise write immediately
	if [ -n "$_batch_mode" ]; then
		_pending_adds="${_pending_adds:+$_pending_adds
}$1:$dev"
	else
		_idlist_add_entry "$1" "$dev"
	fi
}

# Dispatch a rule ID to the appropriate add function (MAC or IP).
# UCI field "mac" is a historical name — it holds either a MAC address or IP/CIDR.
_add_rule() {
	local id=$1 device
	device=$(_get_uci_field "@network_$id" "mac")
	if is_macaddr "$device"; then
		add_mac "$id"
	else
		add_ip "$id"
	fi
}

# Re-add rules for a network that are both enabled AND currently scheduled active.
# Used after tc infrastructure rebuild (shared-device restart, resync).
# Single awk pass extracts IDs + schedule data; check_item is pure shell (0 forks).
_readd_network_rules() {
	local net=$1
	[ -n "$_uci_cache" ] || _uci_cache=$(uci show "$NAME" 2>/dev/null)

	# Single date fork for current time
	local now_h now_m now_w
	read now_h now_m now_w <<EOF
$(date +'%H %M %u')
EOF

	# Single awk pass: extract enabled rule IDs with schedule fields
	# Output format: id|timestart|timeend|week
	local _sched_data
	_sched_data=$(echo "$_uci_cache" | awk -v net="@network_${net}[" '
	function uq(s) {
		sub(/[^=]*=/, "", s)
		gsub(/\047\\\047\047/, "\001", s); gsub(/\047/, "", s); gsub(/\001/, "\047", s)
		return s
	}
	index($0, net) {
		match($0, /@network_[^.]+/)
		id = substr($0, RSTART+9, RLENGTH-9)
		f = $0; sub(/.*@network_[^.]+\./, "", f); sub(/=.*/, "", f)
		v = uq($0)
		if (f == "enable" && v == "1") en[id] = 1
		else if (f == "timestart") ts[id] = v
		else if (f == "timeend") te[id] = v
		else if (f == "week") wk[id] = v
	}
	END { for (id in en) print id "|" ts[id] "|" te[id] "|" wk[id] }')

	# Batch IDLIST writes: enable batch mode, add rules, flush once
	_batch_mode=1; _pending_adds=""
	local _rid _ts _te _wk
	while IFS='|' read -r _rid _ts _te _wk; do
		[ -n "$_rid" ] || continue
		check_item "$_rid" "$_ts" "$_te" "$_wk" "$now_h" "$now_m" "$now_w" \
			&& _add_rule "$_rid"
	done <<EOF
$_sched_data
EOF
	_idlist_batch_add "$_pending_adds"
	_batch_mode=""; _pending_adds=""
}

case "$crrun" in
	"stop")
		log_msg 2 "=== eqosplus stopping ==="
		stop_qos
		> "$IDLIST"
		> "$NETWORKS"
	;;
	"start")
		rm -f /var/$NAME.tmpid.* 2>/dev/null
		# Rotate log on start: keep last 10KB for debugging restart issues
		if [ -f "$LOGFILE" ]; then
			_sz=$(stat -c %s "$LOGFILE" 2>/dev/null || wc -c < "$LOGFILE" 2>/dev/null) || _sz=0
			if [ "$_sz" -gt 10240 ]; then
				tail -c 10240 "$LOGFILE" > "${LOGFILE}.tmp" && mv "${LOGFILE}.tmp" "$LOGFILE" || rm -f "${LOGFILE}.tmp"
			fi
		fi
		log_msg 2 "=== eqosplus starting ==="
		cleanup_orphaned_rules
		_uci_cache=""  # invalidate after cleanup may have modified UCI
		_enabled_networks_cache=""
		> "$IDLIST"
		> "$NETWORKS"
		bump_generation
		init_qosplus
	;;
	"add")
		[ -n "$_uci_cache" ] || _uci_cache=$(uci show "$NAME" 2>/dev/null)
		_batch_mode=1; _pending_adds=""
		_oifs="$IFS"; IFS=,; set -f
		for id in $crid ;do
			_add_rule "$id"
		done
		IFS="$_oifs"; set +f
		_idlist_batch_add "$_pending_adds"
		_batch_mode=""; _pending_adds=""
		bump_generation
	;;
	"del")
		_batch_mode=1; _pending_dels=""
		_oifs="$IFS"; IFS=,; set -f
		for id in $crid ;do
			del_id "$id"
		done
		IFS="$_oifs"; set +f
		_idlist_batch_remove "$_pending_dels"
		_batch_mode=""; _pending_dels=""
		bump_generation
	;;
	"resync")
		[ -n "$crid" ] || exit 1
		log_msg 2 "=== resync network $crid ==="
		# Remove network from NETWORKS (so sync_networks will re-initialize it)
		_file_remove_exact_line "$NETWORKS" "$crid"
		# Remove this network's rules from IDLIST
		_idlist_remove_network "$crid"
		# Re-initialize tc infrastructure for this network
		_uci_cache=""
		_enabled_networks_cache=""
		sync_networks
		# Re-add enabled rules immediately to avoid QoS gap until daemon's next poll
		# Guard: only readd if sync_networks actually started this network
		grep -qFx "$crid" "$NETWORKS" 2>/dev/null && _readd_network_rules "$crid"
		bump_generation
	;;
	"status")
		if [ ! -s "$NETWORKS" ]; then
			echo "No active networks. Is the service running?"
			exit 0
		fi
		while IFS= read -r network; do
			[ -n "$network" ] || continue
			dev=$(get_net_device "$network")
			[ -n "$dev" ] || continue
			echo "### Statistics $dev ###"
			echo "# qdiscs #"
			tc -s qdisc show dev "$dev"
			echo "# class #"
			tc -s class show dev "$dev"
			echo "# filter #"
			tc -s filter show dev "$dev" root
			tc -s filter show dev "$dev" parent 1:
			echo "### Statistics  ${dev}_ifb ###"
			echo "# qdiscs #"
			tc -s qdisc show dev "${dev}_ifb"
			echo "# class #"
			tc -s class show dev "${dev}_ifb"
			echo "# filter #"
			tc -s filter show dev "${dev}_ifb" root
			tc -s filter show dev "${dev}_ifb" parent 1:
		done < "$NETWORKS" 2>/dev/null
	;;
	"log")
		cat "$LOGFILE" 2>/dev/null
	;;

esac
