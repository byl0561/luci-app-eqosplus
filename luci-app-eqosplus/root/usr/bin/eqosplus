#!/bin/bash

# Copyright (C) 2006 OpenWrt.org
# Copyright 2022-2025 lava <byl0561@gmail.com>

crrun=$1
crid=$2
NAME=eqosplus
IDLIST="/var/$NAME.idlist"
TMPID="/var/$NAME.tmpid"
NETWORKS="/var/$NAME.networks"
LOGFILE="/tmp/$NAME.log"
LOG_LEVEL=$(uci -q get $NAME.@eqosplus[0].log_level 2>/dev/null || echo 0)
bin_tc=$(which tc)
bin_ip=$(which ip)

touch $IDLIST
touch $NETWORKS

# Logging: 0=off, 1=error, 2=info, 3=debug
log_msg() {
	local level=$1; shift
	[ "$LOG_LEVEL" -ge "$level" ] 2>/dev/null || return
	local tag=""
	case $level in
		1) tag="ERROR" ;;
		2) tag="INFO" ;;
		3) tag="DEBUG" ;;
	esac
	echo "$(date '+%H:%M:%S') [$tag] $*" >> $LOGFILE
	# Truncate log if > 100KB
	local size=$(wc -c < "$LOGFILE" 2>/dev/null || echo 0)
	[ "$size" -gt 102400 ] && tail -c 51200 "$LOGFILE" > "${LOGFILE}.tmp" && mv "${LOGFILE}.tmp" "$LOGFILE"
}

dbg_tc() {
	log_msg 3 "tc $*"
	$bin_tc $*
	local ret=$?
	[ $ret -eq 0 ] || log_msg 1 "tc FAILED (exit=$ret): $*"
	return $ret
}
dbg_ip() {
	log_msg 3 "ip $*"
	$bin_ip $*
	local ret=$?
	[ $ret -eq 0 ] || log_msg 1 "ip FAILED (exit=$ret): $*"
	return $ret
}
is_macaddr() {
    if echo "$1" | grep -qE '^([0-9A-Fa-f]{2}[-:]){5}[0-9A-Fa-f]{2}$'; then
        return 0
    fi
    return 1
}

# Default commands
tc="dbg_tc"
ip="dbg_ip"

start_network() {
	network=$1
	dev=$(uci get network.$network.device)
	log_msg 2 "start_network $network dev=$dev"

	$ip link add dev ${dev}_ifb name ${dev}_ifb type ifb
	$ip link set dev ${dev}_ifb up
	$tc qdisc add dev ${dev} root handle 1:0 htb default 1
	$tc class add dev ${dev} parent 1:0 classid 1:1 htb rate 10gbit prio 0 quantum 1500
	$tc qdisc add dev ${dev} parent 1:1 fq_codel

	$tc qdisc add dev ${dev}_ifb root handle 1:0 htb default 1
	$tc class add dev ${dev}_ifb parent 1:0 classid 1:1 htb rate 10gbit prio 0 quantum 1500
	$tc qdisc add dev ${dev}_ifb parent 1:1 fq_codel

	# Bypass LAN-to-LAN traffic: detect all LAN subnets from bridge devices
	local bypass_prio=1
	for br in $(ip link show type bridge 2>/dev/null | awk -F: '{print $2}' | tr -d ' '); do
		for subnet in $(ip -4 -o addr show dev $br 2>/dev/null | awk '{print $4}'); do
			log_msg 2 "bypass: IPv4 $subnet on $br"
			$tc filter add dev ${dev} parent 1:0 prio $bypass_prio protocol ip flower src_ip $subnet classid 1:1
			$tc filter add dev ${dev}_ifb parent 1:0 prio $bypass_prio protocol ip flower dst_ip $subnet classid 1:1
			bypass_prio=$((bypass_prio + 1))
		done
		for subnet in $(ip -6 -o addr show dev $br scope global 2>/dev/null | awk '{print $4}'); do
			log_msg 2 "bypass: IPv6 $subnet on $br"
			$tc filter add dev ${dev} parent 1:0 prio $bypass_prio protocol ipv6 flower src_ip $subnet classid 1:1
			$tc filter add dev ${dev}_ifb parent 1:0 prio $bypass_prio protocol ipv6 flower dst_ip $subnet classid 1:1
			bypass_prio=$((bypass_prio + 1))
		done
	done

	$tc qdisc add dev ${dev} ingress

	echo "${network}" >> $NETWORKS ;  cat $NETWORKS | sort | uniq  > $TMPID ;cat $TMPID >$NETWORKS ;rm -rf $TMPID
}

stop_network() {
	network=$1
	dev=$(uci get network.$network.device)
	log_msg 2 "stop_network $network dev=$dev"

	$tc filter del dev ${dev} parent ffff: 2>/dev/null
	$tc qdisc del dev ${dev} ingress 2>/dev/null

	$tc filter del dev ${dev}_ifb parent 1:0 2>/dev/null
	$tc filter del dev ${dev} parent 1:0 2>/dev/null

	$tc qdisc del dev ${dev} root 2>/dev/null
	$tc qdisc del dev ${dev}_ifb root 2>/dev/null

	$ip link del dev ${dev}_ifb 2>/dev/null

	sed -i "/$network/d" $NETWORKS >/dev/null 2>&1
}

sync_networks() {
	all_networks=()
	for network in $(uci show $NAME | grep "enable='1'" | grep "network_" | grep -oE '@network_[^.]+' | sed 's/@network_//' | sed 's/\[.*\]//'); do
		network_exists=false
		for net in "${all_networks[@]}"; do
			if [[ "$net" == "$network" ]]; then
				network_exists=true
				break
			fi
		done
		if [[ "$network_exists" == false ]]; then
			all_networks+=("$network")
		fi
	done

	need_start=()
	need_stop=()
	running_networks=`cat $NETWORKS `
	for item in "${all_networks[@]}"; do
		item_exists=false
		for net in $running_networks; do
			if [[ "$net" == "$item" ]]; then
				item_exists=true
				break
			fi
		done
		if [[ "$item_exists" == false ]]; then
			need_start+=("$item")
		fi
	done
	for item in $running_networks; do
		item_exists=false
		for net in "${all_networks[@]}"; do
			if [[ "$net" == "$item" ]]; then
				item_exists=true
				break
			fi
		done
		if [[ "$item_exists" == false ]]; then
			need_stop+=("$item")
		fi
	done

	for item in "${need_start[@]}"; do
		start_network $item
	done

	for item in "${need_stop[@]}"; do
		stop_network $item
	done
}

stop_qos() {
	running_networks=`cat $NETWORKS `
	for item in $running_networks; do
		stop_network $item
	done
}

init_qosplus() {
	sync_networks
}

cal_uuid() {
	network=`echo $1 | sed 's/\[.*\]//' `
	rule_id=`echo $1 | sed -n 's/.*\[\([0-9]*\)\]/\1/p' `

	network_id=0
	running_networks=`cat $NETWORKS `
	for running_network in $running_networks; do
		if [ "$network" == "$running_network" ]; then
			break
		fi
		network_id=$((network_id + 1))
	done

	echo `echo -n "$network_id" | awk -v n="$rule_id" '{printf "%d", ($1 + 11) "00" + n * 2}' `
}

del_id() {
	device=$(uci -q get $NAME.@network_$1.mac )
	network=`echo $1 | sed 's/\[.*\]//' `
	dev=$(uci get network.$network.device)
	id=$(cal_uuid $1)

	log_msg 2 "del_id $1 id=$id device=$device dev=$dev"
	$tc qd del dev ${dev} parent 1:$id  2>/dev/null
	$tc qd del dev ${dev}_ifb parent 1:$id 2>/dev/null

	$tc class del dev ${dev} parent 1:1 classid 1:$id 2>/dev/null
	$tc class del dev ${dev}_ifb parent 1:1 classid 1:$id 2>/dev/null

	$tc filter del dev ${dev} parent ffff: prio $id 2>/dev/null
	$tc filter del dev ${dev}_ifb pref $id 2>/dev/null
	$tc filter del dev ${dev} pref $id 2>/dev/null

	escaped_id=$(echo "$1" | sed 's/\[/\\[/g; s/\]/\\]/g')
	sed -i "/$escaped_id/d" $IDLIST >/dev/null 2>&1
}

add_mac() {
	mac=$(uci -q get $NAME.@network_$1.mac )
	DL=$(uci -q get $NAME.@network_$1.download 2>/dev/null | awk '{printf "%d", $1*8*1000}')
	UL=$(uci -q get $NAME.@network_$1.upload   2>/dev/null | awk '{printf "%d", $1*8*1000}')
	network=`echo $1 | sed 's/\[.*\]//' `
	dev=$(uci get network.$network.device)
	id=$(cal_uuid $1)

	log_msg 2 "add_mac $1 id=$id mac=$mac UL=${UL}kbit DL=${DL}kbit dev=$dev"
	if [ "$UL" -gt 0 ]; then
		$tc filter add dev ${dev} parent ffff: prio $id protocol all flower src_mac $mac action mirred egress redirect dev ${dev}_ifb
		$tc class add dev ${dev}_ifb parent 1:1 classid 1:$id htb rate "$UL"kbit ceil "$UL"kbit prio $id quantum 1500
		$tc qdisc add dev ${dev}_ifb parent 1:"$id" handle "$id": fq_codel
		$tc filter add dev ${dev}_ifb parent 1: prio $id protocol all flower src_mac $mac classid 1:$id
	fi
	if [ "$DL" -gt 0 ]; then
		$tc class add dev ${dev} parent 1:1 classid 1:$id htb rate "$DL"kbit ceil "$DL"kbit prio $id quantum 1500
		$tc qdisc add dev ${dev} parent 1:"$id" handle "$id": fq_codel
		$tc filter add dev ${dev} parent 1: prio $id protocol all flower dst_mac $mac classid 1:$id
	fi

	echo "$1" >> $IDLIST ;  cat $IDLIST | sort | uniq  > $TMPID ;cat $TMPID >$IDLIST ;rm -rf $TMPID
}

add_ip() {
	ip=$(uci -q get $NAME.@network_$1.mac )
	DL=$(uci -q get $NAME.@network_$1.download 2>/dev/null | awk '{printf "%d", $1*8*1000}')
	UL=$(uci -q get $NAME.@network_$1.upload   2>/dev/null | awk '{printf "%d", $1*8*1000}')
	network=`echo $1 | sed 's/\[.*\]//' `
	dev=$(uci get network.$network.device)
	id=$(cal_uuid $1)

	Z=`echo $ip |awk -F '[/]' '{print $2}' `
	[ -n "$Z" ] && ip=`echo $ip |awk -F '[/]' '{print $1}' `|| Z=32
	log_msg 2 "add_ip $1 id=$id ip=$ip/$Z UL=${UL}kbit DL=${DL}kbit dev=$dev"
	if [ "$UL" -gt 0 ]; then
		$tc filter add dev ${dev} parent ffff: prio $id protocol ip flower src_ip $ip/$Z action mirred egress redirect dev ${dev}_ifb
		$tc class add dev ${dev}_ifb parent 1:1 classid 1:$id htb rate "$UL"kbit ceil "$UL"kbit prio $id quantum 1500
		$tc qdisc add dev ${dev}_ifb parent 1:"$id" handle "$id": fq_codel
		$tc filter add dev ${dev}_ifb parent 1:0 prio $id protocol ip flower src_ip $ip/$Z classid 1:$id
	fi
	if [ "$DL" -gt 0 ]; then
		$tc class add dev ${dev} parent 1:1 classid 1:$id htb rate "$DL"kbit ceil "$DL"kbit prio $id quantum 1500
		$tc qdisc add dev ${dev} parent 1:"$id" handle "$id": fq_codel
		$tc filter add dev ${dev} parent 1:0 prio $id protocol ip flower dst_ip $ip/$Z classid 1:$id
	fi

	echo "$1" >> $IDLIST ;  cat $IDLIST | sort | uniq  > $TMPID ;cat $TMPID >$IDLIST ;rm -rf $TMPID
}

case "$crrun" in
	"stop")
		log_msg 2 "=== eqosplus stopping ==="
		stop_qos
		> $IDLIST
		> $NETWORKS
	;;
	"start")
		> $LOGFILE
		log_msg 2 "=== eqosplus starting ==="
		> $IDLIST
		> $NETWORKS
		init_qosplus
	;;
	"add")
		for id in `echo $crid | sed 's/,/ /g' ` ;do
			device=$(uci -q get $NAME.@network_$id.mac )
			if is_macaddr $device; then
				add_mac $id
			else
				add_ip $id
			fi
		done
	;;
	"del")
		for id in `echo $crid | sed 's/,/ /g' ` ;do
			del_id $id
		done
	;;
	"status")
		running_networks=`cat $NETWORKS `
		for network in $running_networks; do
			dev=$(uci get network.$network.device)
			echo "### Statistics $dev ###"
			echo "# qdiscs #"
			tc -s qdisc show dev $dev
			echo "# class #"
			tc -s class show dev $dev
			echo "# filter #"
			tc -s filter show dev $dev root
			tc -s filter show dev $dev parent 1:
			echo "### Statistics  ${dev}_ifb ###"
			echo "# qdiscs #"
			tc -s qdisc show dev ${dev}_ifb
			echo "# class #"
			tc -s class show dev ${dev}_ifb
			echo "# filter #"
			tc -s filter show dev ${dev}_ifb root
			tc -s filter show dev ${dev}_ifb parent 1:
		done
	;;
	"log")
		cat $LOGFILE 2>/dev/null
	;;

esac
